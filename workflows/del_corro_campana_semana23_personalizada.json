    {
      "parameters": {
        "jsCode": "const row = $('Loop por PDV').first().json;\nconst matches = $input.all().map((i) => i.json).filter((c) => c && c.id != null);\nconst cfg = {\n  dia_visita: String(row.dia_visita || '').toLowerCase(),\n  crear: row.crear_cliente_si_no_existe,\n  telefono_sheet: row.telefono_sheet,\n};\n\nlet client = matches[0] || null;\nlet skip_reason = null;\n\nif (!client) {\n  if (cfg.crear && cfg.telefono_sheet) {\n    return [{\n      json: {\n        ...row,\n        action: 'create',\n        phone_number: cfg.telefono_sheet,\n        client_id: null,\n      },\n    }];\n  }\n  skip_reason = 'cliente_no_encontrado_sin_telefono_en_sheet';\n} else {\n  const dia = String(client.dia_de_visita || '').toLowerCase();\n  const diaOk = dia === cfg.dia_visita || (cfg.dia_visita === 'miercoles' && dia === 'miércoles');\n  if (!diaOk) skip_reason = `dia_visita_${dia}_!=_${cfg.dia_visita}`;\n  const phone = String(client.phone_number || '').replace(/\\D/g, '');\n  if (!skip_reason && phone.length < 10) skip_reason = 'sin_telefono_en_bd';\n  if (!skip_reason && client.activo_ai === false) skip_reason = 'activo_ai_false';\n}\n\nif (skip_reason) {\n  return [{ json: { ...row, action: 'skip', skip_reason, client } }];\n}\n\nreturn [{\n  json: {\n    ...row,\n    action: 'send',\n    client_id: client.id,\n    phone_number: String(client.phone_number).replace(/\\D/g, ''),\n    dia_de_visita: client.dia_de_visita,\n    client,\n  },\n}];"
      },
