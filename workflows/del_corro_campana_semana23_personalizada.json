    {
      "parameters": {
        "jsCode": "const cfg = $('Config').first().json;\nconst diaVisita = String(cfg.dia_visita || 'martes').trim().toLowerCase();\n\nfunction normCodigo(v) {\n  const s = String(v ?? '').trim();\n  if (!s) return null;\n  const n = Number(s.replace(/,/g, '.'));\n  return Number.isFinite(n) ? String(n) : null;\n}\n\nfunction normPhone(v) {\n  if (!v) return null;\n  const digits = String(v).replace(/\\D/g, '');\n  return digits.length >= 10 ? digits : null;\n}\n\nfunction firstName(razon) {\n  const t = String(razon || '').trim();\n  if (!t) return 'Cliente';\n  return t.split(/\\s+/)[0];\n}\n\nfunction prodLine(name, code) {\n  const n = String(name || '').trim();\n  const c = String(code || '').trim();\n  if (!n || n.toUpperCase() === 'N/A') return null;\n  return c && c.toUpperCase() !== 'N/A' ? `${n} (${c})` : n;\n}\n\nfunction trunc(s, max = 900) {\n  const t = String(s || '').trim();\n  return t.length > max ? `${t.slice(0, max - 1)}…` : t;\n}\n\nconst out = [];\nfor (const item of $input.all()) {\n  const row = item.json;\n  const codigo = normCodigo(row.Cliente ?? row.cliente);\n  if (!codigo) continue;\n\n  const parrafo = trunc(row.Parrafo_Personalizado ?? row.parrafo_personalizado ?? '');\n  const lines = [\n    prodLine(row.Producto_1, row.Codigo_1),\n    prodLine(row.Producto_2, row.Codigo_2),\n    prodLine(row.Producto_3, row.Codigo_3),\n  ].filter(Boolean);\n  const productos_bloque = lines.length ? lines.map((l) => `• ${l}`).join('\\n') : '• (sin productos sugeridos)';\n\n  out.push({\n    json: {\n      schema: cfg.schema,\n      dia_visita: diaVisita,\n      codigo,\n      razon_social: String(row.Razon_Social ?? row.razon_social ?? '').trim(),\n      rubro: String(row.Rubro ?? '').trim(),\n      parrafo,\n      producto_1: String(row.Producto_1 ?? '').trim(),\n      codigo_1: String(row.Codigo_1 ?? '').trim(),\n      producto_2: String(row.Producto_2 ?? '').trim(),\n      codigo_2: String(row.Codigo_2 ?? '').trim(),\n      producto_3: String(row.Producto_3 ?? '').trim(),\n      codigo_3: String(row.Codigo_3 ?? '').trim(),\n      telefono_sheet: normPhone(row.Telefono ?? row.telefono),\n      template_name: cfg.template_name,\n      language_code: cfg.language_code,\n      dry_run: cfg.dry_run === true || cfg.dry_run === 'true',\n      crear_cliente_si_no_existe:\n        cfg.crear_cliente_si_no_existe === true || cfg.crear_cliente_si_no_existe === 'true',\n      body_params: [\n        firstName(row.Razon_Social),\n        parrafo,\n        String(row.Producto_1 ?? '-').trim() || '-',\n        String(row.Codigo_1 ?? '-').trim() || '-',\n        String(row.Producto_2 ?? '-').trim() || '-',\n        String(row.Codigo_2 ?? '-').trim() || '-',\n        String(row.Producto_3 ?? '-').trim() || '-',\n        String(row.Codigo_3 ?? '-').trim() || '-',\n      ],\n      mensaje_preview: `Hola ${firstName(row.Razon_Social)}!\\n\\n${parrafo}\\n\\n${productos_bloque}`,\n    },\n  });\n}\n\nreturn out;"
      },
