      "id": "a1b2c3d4-0006-4000-8000-000000000006",
      "name": "Supabase — buscar client",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [1200, 0],
      "credentials": {
        "supabaseApi": {
          "id": "CONFIGURE_IN_N8N",
