# Copiar a .env y completar (nunca commitear .env).
# cp .env.example .env

# auto = ElevenLabs → OpenAI → macOS (recomendado)
PODCAST_TTS_BACKEND=auto

# ElevenLabs — https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Host por defecto: Facundo (Adam). Alternativa J.A.R.V.I.S.: George (británico).
# PODCAST_VOICE_ID=pNInz6obpgDQGcFmaJgB   # Adam — Facundo, acento neutro/inglés
PODCAST_VOICE_ID=JBFqnCBsd6RMkjVDRZzb      # George — estilo J.A.R.V.I.S. (Iron Man)
# PODCAST_VOICE_ID=onwK4e9ZLuTAKqWW03F9   # Daniel — británico más grave/documental
ELEVEN_MODEL=eleven_multilingual_v2

# OpenAI — fallback si ElevenLabs falla (créditos, rate limit, red)
OPENAI_API_KEY=
OPENAI_VOICE=onyx
OPENAI_MODEL=gpt-4o-mini-tts

# Último fallback macOS (sin credenciales ni red)
# MACOS_VOICE=Reed
# RATE=170
