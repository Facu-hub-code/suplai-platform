.DS_Store
.env
.env.*
!.env.example
*.pem
credentials.json

# MCP local (tokens personales; usar los .example como plantilla)
.cursor/mcp.local.json
.cursor/mcp.n8n.json

# Antigravity (Toto) + skills vendor (skills.sh → .agents/skills/)
.agents/

# Symlinks Cursor → .agents/skills/ (generados por scripts/install-vendor-skills.sh)
.cursor/skills/_vendor/*
!.cursor/skills/_vendor/README.md

scratch/

# Git worktrees locales (una feature / agente por directorio)
.worktrees/
.worktree-dev.env
.worktree-setup-stamp

scripts/__pycache__/
scripts/*/__pycache__/

# Reportes E2E generados localmente (test_agent_e2e.py)
implementacion/**/outputs/reporte_e2e_*.md

# Spec podcast — artefactos de audio/guion generados localmente (skill spec-podcast)
.tmp-audio-demo/
.cursor/skills/spec-podcast/output/**/*
!.cursor/skills/spec-podcast/output/.gitignore
!.cursor/skills/spec-podcast/output/.gitkeep